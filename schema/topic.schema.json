{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PoH Topic",
    "type": "object",
    "required": [
        "roundId",
        "topic",
        "generatedAt"
    ],
    "properties": {
        "roundId": {
            "type": "integer",
            "description": "Round ID (integer in YYYYMMDD format)",
            "minimum": 20260101
        },
        "topic": {
            "type": "string",
            "description": "Topic text",
            "minLength": 1
        },
        "topicEn": {
            "type": [
                "string",
                "null"
            ],
            "description": "English translation of the topic (optional)"
        },
        "generatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Topic generation date and time (ISO8601)"
        }
    },
    "additionalProperties": false
}